IF OBJECT_ID('dbo.execution_orders', 'U') IS NULL
BEGIN
    CREATE TABLE dbo.execution_orders (
      
        order_id NVARCHAR(50) NOT NULL,
        symbol NVARCHAR(20) NOT NULL,
        side NVARCHAR(20) NOT NULL,
        quantity INT NOT NULL,
        filled_qty INT NULL,
        remaining_qty INT NULL,
        avg_fill_price DECIMAL(18,4) NULL,
        order_type NVARCHAR(20) NOT NULL,
        limit_price DECIMAL(18,4) NULL,
        status NVARCHAR(30) NOT NULL,
        create_time NVARCHAR(30) NULL,
        update_time NVARCHAR(30) NULL,
        reject_reason NVARCHAR(255) NULL,
        strategy_name NVARCHAR(100) NULL,
        signal_id NVARCHAR(100) NULL,
        client_order_id NVARCHAR(100) NULL,
        note NVARCHAR(255) NULL
    );
END;
GO

IF OBJECT_ID('dbo.execution_fills', 'U') IS NULL
BEGIN
    CREATE TABLE dbo.execution_fills (
        
        order_id NVARCHAR(50) NOT NULL,
        symbol NVARCHAR(20) NOT NULL,
        side NVARCHAR(20) NOT NULL,
        fill_qty INT NOT NULL,
        fill_price DECIMAL(18,4) NOT NULL,
        fill_time NVARCHAR(30) NULL,
        commission DECIMAL(18,4) NULL,
        tax DECIMAL(18,4) NULL,
        slippage DECIMAL(18,6) NULL,
        strategy_name NVARCHAR(100) NULL,
        signal_id NVARCHAR(100) NULL,
        note NVARCHAR(255) NULL
    );
END;
GO